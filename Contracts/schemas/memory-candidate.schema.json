{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aire.local/contracts/memory-candidate.schema.json",
  "title": "Memory Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "type",
    "summary",
    "source_ids",
    "source_mode",
    "occurred_at",
    "confidence"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "type": {
      "type": "string",
      "enum": ["UserSharedEvent", "Promise", "Preference", "RelationshipMoment"]
    },
    "summary": { "type": "string", "minLength": 1, "maxLength": 512 },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "source_mode": { "type": "string", "enum": ["InGame", "Offline"] },
    "occurred_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
