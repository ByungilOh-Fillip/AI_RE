{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aire.local/contracts/ai-service-request.schema.json",
  "title": "AIService Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "current_message_id",
    "allowed_event_ids",
    "interaction_mode",
    "companion_id",
    "user_message",
    "time_context",
    "game_context",
    "retrieved_memories",
    "allowed_commands"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "current_message_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Current user Message ID. Memory candidates may cite it as a source."
    },
    "allowed_event_ids": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 },
      "description": "Backend-verified Event IDs that memory candidates may cite."
    },
    "interaction_mode": { "type": "string", "enum": ["InGame", "Offline"] },
    "companion_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "user_message": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "time_context": { "$ref": "./time-context.schema.json" },
    "game_context": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "not": {
          "enum": [
            "authorization",
            "access_token",
            "connection_string",
            "database_url",
            "device_id",
            "device_token",
            "pairing_code",
            "password",
            "profile_id",
            "runtime_secret",
            "secret",
            "token"
          ]
        }
      },
      "description": "Purpose-limited, validated context. It must not contain credentials, database keys, or device identity."
    },
    "retrieved_memories": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["memory_id", "summary", "source_ids", "occurred_at"],
        "properties": {
          "memory_id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 512 },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 128 }
          },
          "occurred_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "allowed_commands": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Command.Follow",
          "Command.HoldPosition",
          "Command.ReturnToPlayer",
          "Command.EngageTarget",
          "Command.DistractTarget",
          "Command.MoveToLocation",
          "Command.CancelCurrent"
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "interaction_mode": { "const": "InGame" } },
        "required": ["interaction_mode"]
      },
      "then": {
        "properties": {
          "time_context": {
            "properties": { "source": { "const": "GameWorld" } },
            "required": ["source"]
          }
        }
      },
      "else": {
        "properties": {
          "time_context": {
            "properties": { "source": { "const": "RealWorld" } },
            "required": ["source"]
          }
        }
      }
    }
  ]
}
