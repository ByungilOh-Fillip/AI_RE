{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aire.local/contracts/event.schema.json",
  "title": "Game Event",
  "allOf": [
    { "$ref": "./common-envelope.schema.json" },
    {
      "type": "object",
      "required": ["event_id", "event_type", "occurred_at", "importance", "actor_id", "target_ids", "payload"],
      "properties": {
        "event_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "event_type": { "type": "string", "pattern": "^Event\\.[A-Za-z0-9.]+$", "maxLength": 128 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "importance": { "type": "string", "enum": ["Low", "Normal", "High", "Critical"] },
        "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "target_ids": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "payload": { "type": "object", "maxProperties": 32 }
      }
    }
  ],
  "unevaluatedProperties": false
}
