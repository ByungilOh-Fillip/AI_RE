{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aire.local/contracts/chat-request.schema.json",
  "title": "Chat Request",
  "allOf": [
    { "$ref": "./common-envelope.schema.json" },
    {
      "type": "object",
      "required": ["message_id", "user_message", "time_context"],
      "properties": {
        "message_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "user_message": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "time_context": { "$ref": "./time-context.schema.json" },
        "recent_event_ids": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        }
      }
    },
    {
      "if": {
        "properties": { "interaction_mode": { "const": "InGame" } },
        "required": ["interaction_mode"]
      },
      "then": {
        "properties": {
          "time_context": {
            "properties": { "source": { "const": "GameWorld" } },
            "required": ["source"]
          }
        }
      },
      "else": {
        "properties": {
          "time_context": {
            "properties": { "source": { "const": "RealWorld" } },
            "required": ["source"]
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
